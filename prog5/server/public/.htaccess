RewriteEngine On

# Allow real files (except PHP) to be served directly (e.g., CSS, JS, images)
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} !\.php$
RewriteRule ^ - [L]

# Route everything else (including PHP files and virtual routes) through index.php
RewriteRule ^(.*)$ index.php [QSA,L]
